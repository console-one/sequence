{
  "name": "@console-one/sequence",
  "version": "0.1.0",
  "description": "Append-only behavioral type kernel. Types and values are the same continuum; mount a fact, see what's missing (gaps), fill gaps through compose, capabilities activate. One operation (mount), one data structure (Sequence), one protocol (ft text in/out).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/console-one/sequence.git"
  },
  "bugs": {
    "url": "https://github.com/console-one/sequence/issues"
  },
  "homepage": "https://github.com/console-one/sequence#readme",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./dsl": {
      "types": "./dist/src/dsl/index.d.ts",
      "import": "./dist/src/dsl/index.js",
      "default": "./dist/src/dsl/index.js"
    },
    "./v2": {
      "types": "./dist/src-v2/index.d.ts",
      "import": "./dist/src-v2/index.js",
      "default": "./dist/src-v2/index.js"
    }
  },
  "files": [
    "dist",
    "specs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "sequence",
    "kernel",
    "append-only",
    "cascade",
    "compose",
    "lattice",
    "behavioral-types",
    "ft"
  ],
  "author": "zerotoprod",
  "license": "MIT",
  "publishConfig": {
    "access": "restricted"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
