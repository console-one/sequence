{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "src-v2/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src-v2/env/browser-storage.ts",
    "src-v2/examples",
    "src-v2/examples/**/*",
    "src-v2/test",
    "src-v2/test/**/*"
  ]
}
