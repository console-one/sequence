#!/usr/bin/env bash
# pre-commit — typecheck the package before letting a commit land.
# Fast enough to run on every commit (a few seconds); catches broken
# imports, unused-var warnings, drift between .d.ts and source.

set -e

cd "$(git rev-parse --show-toplevel)"

echo "[pre-commit] tsc --noEmit"
npx --no-install tsc --noEmit

echo "[pre-commit] OK"
